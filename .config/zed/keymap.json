// Zed keymap
// docs: https://zed.dev/docs/key-bindings
[
	{
		"context": "Pane",
		"bindings": {
			"ctrl-tab": "pane::ActivateNextItem",
			"ctrl-shift-tab": "pane::ActivatePreviousItem",
		},
	},
	{
		"context": "Editor",
		"bindings": {
			"cmd-shift-r": "editor::Rename",
		},
	},
	{
		"context": "Editor",
		"bindings": {
			"f2": null,
		},
	},
]
