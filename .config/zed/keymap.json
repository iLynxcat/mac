// Zed keymap
//   https://zed.dev/docs/key-bindings
[
	{
		"context": "Pane",
		"bindings": {
			"ctrl-tab": "pane::ActivateNextItem",
			"ctrl-shift-tab": "pane::ActivatePreviousItem",
		},
	},
	{
		"context": "Editor && vim_mode == insert",
		"bindings": {
			"cmd-shift-r": "editor::Rename",
		},
	},
	{
		"context": "Workspace",
		"bindings": {
			"cmd-r": "debugger::Start",
		},
	},
	{
		"context": "Editor",
		"bindings": {
			"cmd-.": null,
		},
	},
	{
		"context": "Editor && vim_mode == normal",
		"bindings": {
			"cmd-.": "debugger::Stop",
		},
	},
	{
		"context": "!Editor",
		"bindings": {
			"cmd-.": "debugger::Stop",
		},
	},
	{
		"context": "Editor && vim_mode != normal",
		"bindings": {
			"cmd-.": "editor::ToggleCodeActions",
		},
	},
	{
		"context": "Workspace",
		"bindings": {
			"cmd-b": "workspace::ToggleRightDock",
		},
	},
	{
		"context": "Workspace",
		"unbind": {
			"alt-cmd-b": "workspace::ToggleRightDock",
		},
	},
	{
		"context": "Workspace",
		"bindings": {
			"alt-cmd-b": "workspace::ToggleLeftDock",
		},
	},
	{
		"context": "Workspace",
		"unbind": {
			"cmd-b": "workspace::ToggleLeftDock",
		},
	},
]
